meta {
  name: Validate token generation request
  type: http
  seq: 1
}

post {
  url: {{host-bff}}/tools/validateTokenGeneration
  body: formUrlEncoded
  auth: none
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

body:form-urlencoded {
  client_assertion: <string>
  client_assertion_type: <string>
  grant_type: <string>
  client_id: <string>
  dpop_proof: <optional dpop proof>
}

docs {
  Provides additional details about token generation request failure.

  Optionally you can send `dpop_proof` to validate the proof used for token generation in the same response.
  The expected target method is `POST`, and the target URL is inferred from the platform configuration.
}
