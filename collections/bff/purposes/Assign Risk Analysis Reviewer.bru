meta {
  name: Assign Risk Analysis Reviewer
  type: http
  seq: 1
}

post {
  url: {{host-bff}}/purposes/:purposeId/riskAnalysis/assign
  body: json
  auth: none
}

params:path {
  purposeId: {{purposeId}}
}

headers {
  Authorization: {{JWT}}
}

body:json {
  {
    "reviewMode": "REVIEWER_WRITES_REVIEWER_SIGNS",
    "reviewerIds": ["{{reviewerId}}"]
  }
}
