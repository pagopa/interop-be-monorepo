meta {
  name: Get Purpose Template Linkable Resources
  type: http
  seq: 14
}

get {
  url: {{host-bff}}/purposeTemplates/:purposeTemplateId/linkableResources
  body: none
  auth: none
}

params:path {
  purposeTemplateId: {{purposeTemplateId}}
}

params:query {
  offset: 0
  limit: 10
  ~q: test
  ~publisherIds: ["{{tenantId}}"]
}

headers {
  Authorization: {{JWT}}
  X-Correlation-Id: {{correlation-id}}
}
