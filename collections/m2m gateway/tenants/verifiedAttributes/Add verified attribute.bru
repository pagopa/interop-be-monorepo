meta {
  name: Add tenant verified attribute
  type: http
  seq: 6
}

post {
  url: {{host-m2m-gw}}/tenants/:tenantId/verifiedAttributes
  body: json
  auth: none
}

params:path {
  tenantId: {{tenantId}}
}

headers {
  Authorization: {{JWT-M2M}}
  Content-Type: application/json
}

body:json {
  {
    "id": "{{attributeId}}",
    "agreementId": "{{agreementId}}"
  }
}
