meta {
  name: Bulk Mark Notifications As Unread
  type: http
  seq: 92
}

post {
  url: {{host-in-app-notification}}/notifications/bulk/markAsUnread
  body: json
  auth: none
}

headers {
  Authorization: {{JWT}}
  X-Correlation-Id: {{correlation-id}}
}

body:json {
  {
    "ids": ["{{notificationId}}"]
  }
}
