meta {
  name: Submit Agreement
  type: http
  seq: 12
}

post {
  url: {{host-agreement}}/agreements/:agreementId/submit
  body: json
  auth: none
}

params:path {
  agreementId: {{agreementId}}
}

headers {
  Authorization: {{JWT}}
  x-correlation-id: {{correlation-id}}
}

body:json {
  {
    "consumerNotes": "Agreement submitted from Bruno collection"
  }
}
