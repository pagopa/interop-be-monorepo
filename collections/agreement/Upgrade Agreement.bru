meta {
  name: Upgrade Agreement
  type: http
  seq: 15
}

post {
  url: {{host-agreement}}/agreements/:agreementId/upgrade
  body: none
  auth: none
}

params:path {
  agreementId: {{agreementId}}
}

headers {
  Authorization: {{JWT}}
  x-correlation-id: {{correlation-id}}
}

vars:post-response {
  agreementId: res.body.id
}
