meta {
  name: Update EService template instance label
  type: http
}

post {
  url: {{host-m2m-gw-v3}}/eserviceTemplates/eservices/:eserviceId/instanceLabel
  body: json
  auth: none
}

params:path {
  eserviceId: {{eserviceId}}
}

headers {
  Authorization: {{DPOP-JWT-M2M-ADMIN}}
  DPoP: {{DPOP-PROOF}}
}

body:json {
  {
    "instanceLabel": "instance-02"
  }
}
