meta {
  name: Schedule archive eservice descriptor
  type: http
  seq: 41
}

post {
  url: {{host-m2m-gw}}/eservices/:eserviceId/descriptors/:descriptorId/scheduleArchive
  body: json
  auth: none
}

params:path {
  eserviceId: {{eserviceId}}
  descriptorId: {{descriptorId}}
}

headers {
  Authorization: {{JWT-M2M-ADMIN}}
}

body:json {
  {
    "gracePeriodDays": 60
  }
}
