meta {
  name: Get certified discrete ttribute
  type: http
  seq: 1
}

get {
  url: {{host-m2m-gw-v3}}/certifiedDiscreteAttributes/:attributeId
  body: none
  auth: none
}

params:path {
  attributeId: {{attributeId}}
}

headers {
  Authorization: {{DPOP-JWT-M2M}}
  DPoP: {{DPOP-PROOF}}
}

docs {
  Retrieves a certified discrete attribute by its ID.
}
