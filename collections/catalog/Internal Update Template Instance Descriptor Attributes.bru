meta {
  name: Internal Update Template Instance Descriptor Attributes
  type: http
  seq: 100
}

post {
  url: {{host-catalog}}/internal/templates/eservices/:eServiceId/descriptors/:descriptorId/attributes/update
  body: json
  auth: none
}

params:path {
  eServiceId: {{eserviceId}}
  descriptorId: {{descriptorId}}
}

headers {
  Authorization: {{JWT}}
  X-Correlation-Id: {{correlation-id}}
}

body:json {
  {
    "certified": [],
    "declared": [],
    "verified": []
  }
}
