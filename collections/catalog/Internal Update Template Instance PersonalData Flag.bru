meta {
  name: Internal Update Template Instance PersonalData Flag
  type: http
  seq: 98
}

post {
  url: {{host-catalog}}/internal/templates/eservices/:eServiceId/personalDataFlag
  body: json
  auth: none
}

params:path {
  eServiceId: {{eserviceId}}
}

headers {
  Authorization: {{JWT}}
  X-Correlation-Id: {{correlation-id}}
}

body:json {
  {
    "personalData": true
  }
}
