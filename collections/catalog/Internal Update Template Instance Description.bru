meta {
  name: Internal Update Template Instance Description
  type: http
  seq: 97
}

post {
  url: {{host-catalog}}/internal/templates/eservices/:eServiceId/description/update
  body: json
  auth: none
}

params:path {
  eServiceId: {{eserviceId}}
}

headers {
  Authorization: {{JWT}}
  X-Correlation-Id: {{correlation-id}}
}

body:json {
  {
    "description": "Updated template instance description"
  }
}
