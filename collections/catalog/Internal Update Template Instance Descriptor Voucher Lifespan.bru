meta {
  name: Internal Update Template Instance Descriptor Voucher Lifespan
  type: http
  seq: 99
}

post {
  url: {{host-catalog}}/internal/templates/eservices/:eServiceId/descriptors/:descriptorId/voucherLifespan/update
  body: json
  auth: none
}

params:path {
  eServiceId: {{eserviceId}}
  descriptorId: {{descriptorId}}
}

headers {
  Authorization: {{JWT}}
  X-Correlation-Id: {{correlation-id}}
}

body:json {
  {
    "voucherLifespan": 86400
  }
}
