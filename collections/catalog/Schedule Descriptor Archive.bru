meta {
  name: Schedule Archive
  type: http
  seq: 37
}

post {
  url: {{host-catalog}}/eservices/:eserviceId/descriptors/:descriptorId/scheduleArchive
  body: json
  auth: none
}

params:path {
  eserviceId: {{eserviceId}}
  descriptorId: {{descriptorId}}
}

headers {
  Authorization: {{JWT}}
  X-Correlation-Id: {{correlation-id}}
}

body:json {
  {
    "gracePeriodDays": 60
  }
}
