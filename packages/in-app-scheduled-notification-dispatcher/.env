# Logger
LOG_LEVEL=info

# Read Model SQL DB
READMODEL_SQL_DB_HOST=localhost
READMODEL_SQL_DB_PORT=6002
READMODEL_SQL_DB_NAME=root
READMODEL_SQL_DB_USERNAME=root
READMODEL_SQL_DB_PASSWORD=root
READMODEL_SQL_DB_USE_SSL=false

# In-App Notification DB (sink: notification table)
IN_APP_NOTIFICATION_DB_HOST=localhost
IN_APP_NOTIFICATION_DB_PORT=6004
IN_APP_NOTIFICATION_DB_NAME=root
IN_APP_NOTIFICATION_DB_USERNAME=root
IN_APP_NOTIFICATION_DB_PASSWORD=root
IN_APP_NOTIFICATION_DB_USE_SSL=false
IN_APP_NOTIFICATION_DB_SCHEMA=notification

# Scheduled Notification DB (work queue)
SCHEDULED_NOTIFICATION_DB_HOST=localhost
SCHEDULED_NOTIFICATION_DB_PORT=6009
SCHEDULED_NOTIFICATION_DB_NAME=root
SCHEDULED_NOTIFICATION_DB_USERNAME=root
SCHEDULED_NOTIFICATION_DB_PASSWORD=root
SCHEDULED_NOTIFICATION_DB_USE_SSL=false
SCHEDULED_NOTIFICATION_DB_SCHEMA=scheduled_notification

# Notification type blocklist (comma-separated)
NOTIFICATION_TYPE_BLOCKLIST=

# Dispatcher tuning
DELIVERY_BATCH_SIZE=100
MAX_ATTEMPTS=5
MAX_BATCHES_PER_RUN=10
SCHEDULED_NOTIFICATION_STALENESS_THRESHOLD_HOURS=24
