# Logger
LOG_LEVEL=info

# Scheduled Notification DB
SCHEDULED_NOTIFICATION_DB_HOST=localhost
SCHEDULED_NOTIFICATION_DB_PORT=6009
SCHEDULED_NOTIFICATION_DB_NAME=root
SCHEDULED_NOTIFICATION_DB_USERNAME=root
SCHEDULED_NOTIFICATION_DB_PASSWORD=root
SCHEDULED_NOTIFICATION_DB_USE_SSL=false
SCHEDULED_NOTIFICATION_DB_SCHEMA=scheduled_notification

# Kafka Consumer
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=scheduled-notification-scheduler
KAFKA_DISABLE_AWS_IAM_AUTH=true
KAFKA_GROUP_ID=scheduled-notification-scheduler-group
KAFKA_LOG_LEVEL=WARN
MSK_ROLE_ARN="arn:aws:iam::000000000000:role/local-msk-role"

# Catalog Topic
CATALOG_TOPIC=event-store.catalog.events

# Reminder thresholds (comma-separated days before archivableOn)
ESERVICE_MANUAL_ARCHIVE_REMINDER_DAYS=7,3,1
ESERVICE_DESCRIPTOR_MANUAL_ARCHIVE_REMINDER_DAYS=7,3,1

# send_at normalization (local hour and timezone)
REMINDER_SEND_AT_HOUR=9
REMINDER_SEND_AT_TZ=Europe/Rome

FEATURE_FLAG_CONFLUENT_KAFKA=true
