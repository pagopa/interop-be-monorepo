LOG_LEVEL=info

KAFKA_CLIENT_ID="producer-keychain-platformstate-writer"
KAFKA_GROUP_ID="producer-keychain-platformstate-writer-group"
KAFKA_BROKERS="localhost:9092"
KAFKA_DISABLE_AWS_IAM_AUTH="true"
MSK_ROLE_ARN="arn:aws:iam::000000000000:role/local-msk-role"
AUTHORIZATION_TOPIC="event-store.authorization.events"
PRODUCER_KEYCHAIN_PLATFORM_STATES_TABLE_NAME="producer-keychain-platform-states"
AWS_CONFIG_FILE=aws.config.local
TOKEN_GENERATION_READMODEL_TABLE_NAME_PLATFORM="platform-states"
TOKEN_GENERATION_READMODEL_TABLE_NAME_TOKEN_GENERATION="token-generation-states"
AWS_REGION="eu-south-1"

FEATURE_FLAG_CONFLUENT_KAFKA=true
