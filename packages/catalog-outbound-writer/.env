LOG_LEVEL=info

KAFKA_CLIENT_ID="catalog"
KAFKA_GROUP_ID="catalog-group-local"
KAFKA_BROKERS="localhost:9092"
KAFKA_DISABLE_AWS_IAM_AUTH="true"
MSK_ROLE_ARN="arn:aws:iam::000000000000:role/local-msk-role"
CATALOG_TOPIC="event-store.catalog.events"

PRODUCER_KAFKA_CLIENT_ID="catalog"
PRODUCER_KAFKA_BROKERS="localhost:9092"
PRODUCER_KAFKA_DISABLE_AWS_IAM_AUTH="true"
CATALOG_OUTBOUND_TOPIC="event-store.catalog-outbound.events"

FEATURE_FLAG_CONFLUENT_KAFKA=true
