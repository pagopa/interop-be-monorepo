LOG_LEVEL=info

KAFKA_CLIENT_ID="purpose"
KAFKA_GROUP_ID="purpose-group-local"
KAFKA_BROKERS="localhost:9092"
KAFKA_DISABLE_AWS_IAM_AUTH="true"
MSK_ROLE_ARN="arn:aws:iam::000000000000:role/local-msk-role"
PURPOSE_TEMPLATE_TOPIC="event-store.purpose_template.events"

PRODUCER_KAFKA_CLIENT_ID="purpose"
PRODUCER_KAFKA_BROKERS="localhost:9092"
PRODUCER_KAFKA_DISABLE_AWS_IAM_AUTH="true"
PURPOSE_TEMPLATE_OUTBOUND_TOPIC="event-store.purpose-template-outbound.events"

FEATURE_FLAG_CONFLUENT_KAFKA=true
