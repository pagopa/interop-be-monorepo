# Logs
LOG_LEVEL=info

# AWS
AWS_REGION=eu-south-1

# Kafka
KAFKA_CLIENT_ID=placeholder
KAFKA_GROUP_ID=placeholder
KAFKA_BROKERS=placeholder
KAFKA_DISABLE_AWS_IAM_AUTH=true

CATALOG_TOPIC=placeholder

# Token generation readmodel
TOKEN_GENERATION_READMODEL_TABLE_NAME_PLATFORM=placeholder
TOKEN_GENERATION_READMODEL_TABLE_NAME_TOKEN_GENERATION=placeholder

# HTTP Service
HOST=0.0.0.0
PORT=3000
WELL_KNOWN_URLS=placeholder
ACCEPTED_AUDIENCES=placeholder

# EventStore DB
EVENTSTORE_DB_HOST=placeholder
EVENTSTORE_DB_NAME=placeholder
EVENTSTORE_DB_USERNAME=placeholder
EVENTSTORE_DB_PASSWORD=placeholder
EVENTSTORE_DB_PORT=5432
EVENTSTORE_DB_SCHEMA=placeholder
EVENTSTORE_DB_USE_SSL=false

# S3 / File Manager
S3_BUCKET=placeholder
ESERVICE_DOCUMENTS_PATH=placeholder
PRODUCER_ALLOWED_ORIGINS=IPA
ESERVICE_TEMPLATE_DOCUMENTS_CONTAINER=placeholder
ESERVICE_TEMPLATE_DOCUMENTS_PATH=placeholder

# Application Audit Producer
SERVICE_VERSION=1
NODE_IP=placeholder
POD_NAME=placeholder
PRODUCER_KAFKA_BROKERS=placeholder
PRODUCER_KAFKA_CLIENT_ID=placeholder
PRODUCER_KAFKA_DISABLE_AWS_IAM_AUTH=true
APPLICATION_AUDIT_TOPIC=placeholder
APPLICATION_AUDIT_FALLBACK_SQS_URL=placeholder

# Minio / S3 Credentials (must match testcontainer seed)
AWS_ACCESS_KEY_ID=testawskey
AWS_SECRET_ACCESS_KEY=testawssecret

# Feature Flags
FEATURE_FLAG_ASYNC_EXCHANGE=true
FEATURE_FLAG_TENANT_KIND_IN_RISK_ANALYSIS=true
